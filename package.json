{
  "name": "dns-sd-browser",
  "version": "0.0.1",
  "description": "Spec-compliant DNS-SD browser over mDNS for Node.js",
  "type": "module",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./lib/index.js"
  },
  "files": [
    "lib",
    "dist"
  ],
  "scripts": {
    "test": "c8 node --test test/**/*.test.js",
    "test:ci": "c8 --reporter=text --reporter=lcov node --test test/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "dns-sd",
    "mdns",
    "bonjour",
    "zeroconf",
    "service-discovery",
    "multicast-dns"
  ],
  "license": "MIT",
  "author": "Gregor MacLennan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gmaclennan/dns-sd-browser.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "c8": "^11.0.0",
    "dns-packet": "^5.6.1",
    "typescript": "^5.7.0"
  }
}
